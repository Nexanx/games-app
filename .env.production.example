APP_DOMAIN=localhost
PUBLIC_APP_URL=http://localhost
HTTP_PORT=80
HTTPS_PORT=443

# Dostęp do całej aplikacji przez Caddy. Hash wygeneruj poleceniem opisanym w README
# i zapisz w pojedynczym cudzysłowie, aby znaki $ pozostały literalne.
APP_BASIC_AUTH_USERNAME=games
APP_BASIC_AUTH_PASSWORD_HASH=''

POSTGRES_DB=games_app
POSTGRES_USER=games
POSTGRES_PASSWORD=change-me

RAWG_API_KEY=
POE_API_TOKEN=

# Chatbot. Wymagane do działania /api/chat; bez nich UI pokaże komunikat o braku konfiguracji.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_MODEL=gemini-3.5-flash
# Maksymalny czas oczekiwania na pojedynczą odpowiedź dostawcy LLM (sekundy).
LLM_REQUEST_TIMEOUT_SECONDS=60
